# Copy to .env to override defaults. All client vars must be prefixed with VITE_.

# Where the API lives. In dev the Vite proxy handles this, so you can leave it unset.
# VITE_API_URL=http://localhost:4000/api
# VITE_SOCKET_URL=http://localhost:4000

# Which restaurant this console manages.
VITE_RESTAURANT_SLUG=green-olive-bistro
